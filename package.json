{
  "name": "openclaw-selflearning",
  "version": "0.1.0",
  "description": "A self-learning OpenClaw extension that turns completed work into durable memory and reusable skills.",
  "type": "module",
  "license": "Apache-2.0",
  "private": false,
  "homepage": "https://github.com/warkcod/openclaw-selflearning#readme",
  "bugs": {
    "url": "https://github.com/warkcod/openclaw-selflearning/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warkcod/openclaw-selflearning.git"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "extension",
    "self-learning",
    "memory",
    "skills"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "openclaw": "^2026.4.14-beta.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.14-beta.1",
      "minGatewayVersion": "2026.4.14-beta.1"
    },
    "build": {
      "openclawVersion": "2026.4.14-beta.1",
      "pluginSdkVersion": "2026.4.14-beta.1"
    }
  }
}
